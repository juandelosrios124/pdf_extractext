# MongoDB (Primary Database)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=pdf_extract_db

# Legacy SQL Database (for backwards compatibility - to be removed)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Migration Settings
MIGRATION_CREATE_BACKUPS=True
MIGRATION_BACKUP_DIR=./migrations/backups

# Application
APP_NAME="FastAPI MVC Application"
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# CORS (JSON array format)
ALLOWED_HOSTS=["http://localhost:3000","http://localhost:8000"]

# Logging Configuration
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Format: text (for dev), json (for production)
LOG_FORMAT=text

# Enable correlation IDs for distributed tracing
LOG_CORRELATION_ID=true
